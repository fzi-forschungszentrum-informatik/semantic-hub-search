+package io.piveau.hub.search.services.datasets;
+
+import co.elastic.clients.elasticsearch.core.search.Hit;
+import co.elastic.clients.json.JsonData;
+import io.piveau.hub.search.Constants;
+import io.piveau.hub.search.engine.SearchClient;
+import io.piveau.hub.search.services.catalogues.CataloguesService;
+import io.piveau.hub.search.services.embeddings.EmbeddingService;
+import io.piveau.hub.search.services.vocabulary.VocabularyService;
+import io.piveau.hub.search.testutil.PollingUtils;
+import io.piveau.hub.search.util.index.IndexManager;
+import io.piveau.hub.search.util.request.QueryParams;
+import io.vertx.core.Future;
+import io.vertx.core.Promise;
+import io.vertx.core.Vertx;
+import io.vertx.core.json.JsonArray;
+import io.vertx.core.json.JsonObject;
+import io.vertx.junit5.Timeout;
+import io.vertx.junit5.VertxExtension;
+import io.vertx.junit5.VertxTestContext;
+import io.vertx.serviceproxy.ServiceBinder;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.DisplayName;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+
+import java.util.List;
+
+import static io.piveau.hub.search.services.datasets.DatasetsService.create;
+import static org.junit.jupiter.api.Assertions.assertFalse;
+import static org.junit.jupiter.api.Assertions.assertNotNull;
+import static org.junit.jupiter.api.Assertions.assertTrue;
+import static org.mockito.ArgumentMatchers.any;
+import static org.mockito.ArgumentMatchers.eq;
+import static org.mockito.Mockito.mock;
+import static org.mockito.Mockito.when;
+
+@ExtendWith(VertxExtension.class)
+public class DatasetsServiceTest {
+
+  @BeforeEach
+  void setUp(Vertx vertx, VertxTestContext testContext) {
+
+    // For our tests we register a real EmbeddingService (with a local Ollama instance) to the Vert.x event bus
+    // This way we can test real embeddings, not only mocked ones
+    JsonObject embeddingConfig = new JsonObject()
+        .put(Constants.ENV_PIVEAU_HUB_SEARCH_EMBEDDING_CONFIG, new JsonObject()
+            .put("url", "http://localhost:11434")
+            .put("model", "paraphrase-multilingual"));
+
+    EmbeddingService.create(vertx, embeddingConfig)
+        .onSuccess(embeddingService -> {
+          new ServiceBinder(vertx)
+              .setAddress(EmbeddingService.SERVICE_ADDRESS)
+              .register(EmbeddingService.class, embeddingService);
+          testContext.completeNow();
+        })
+        .onFailure(testContext::failNow);
+
+    // TODO: Implement EmbeddingService and SearchClient as Mockito Mocks
+  }
+
+  /**
+   * Creates a test configuration for Elasticsearch, providing host, port, scheme,
+   * and index-specific settings such as mappings, settings files, index templates,
+   * and policies for different document types. The configuration is based on the
+   * default settings and can be used for testing the integration with Elasticsearch.
+   *
+   * @return a {@link JsonObject} representing the Elasticsearch test configuration.
+   */
+  JsonObject createElasticsearchTestConfig() {
+    return new JsonObject()
+        .put("host", "localhost")
+        .put("port", 9200)
+        .put("scheme", "http")
+        .put("index", new JsonObject()
+            .put(Constants.DOC_TYPE_DATASET, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/dataset/standard.json"))
+            .put(Constants.DOC_TYPE_CATALOGUE, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/catalogue/standard.json"))
+            .put(Constants.DOC_TYPE_DATASERVICE, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/dataservice/standard.json"))
+            .put(Constants.DOC_TYPE_VOCABULARY, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json"))
+                // .put("mapping", "conf/elasticsearch/mapping/vocabulary/standard.json"))
+            .put(Constants.DOC_TYPE_DATASETREVISIONS, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/dataset/standard.json")
+                .put("indexTemplate", "conf/elasticsearch/indexTemplate.json")
+                .put("policy", "conf/elasticsearch/policy.json"))
+        ).put(Constants.DOC_TYPE_VOCABULARY, new JsonObject());
+  }
+
+  @Test
+  @DisplayName("Test reindexing with embeddings for all documents")
+  @Timeout(value = 120, timeUnit = java.util.concurrent.TimeUnit.MINUTES) // Embeddings may take a while to generate
+  void testEmbeddingGeneration(Vertx vertx, VertxTestContext testContext) {
+
+    JsonObject esConfig = createElasticsearchTestConfig();
+    IndexManager indexManager = IndexManager.create(vertx, esConfig, null);
+    DatasetsService datasetService = create(vertx, esConfig, indexManager).result();
+    SearchClient searchClient = SearchClient.build(vertx, esConfig, indexManager);
+
+    PollingUtils.waitForElasticsearchReady(
+          vertx,
+          esConfig.getString("host", "localhost"),
+          esConfig.getInteger("port", 9200)
+        )
+        // .compose(v -> datasetService.triggerReindexingWithEmbeddings()) // TODO: Remove
+        .compose(v -> datasetService.triggerDatasetEmbeddingEnrichment())
+        .compose(v -> {
+            // Make sure ES index has refreshed, by waiting for 2 seconds
+            Promise<Void> refreshPromise = Promise.promise();
+            vertx.setTimer(2000, id -> refreshPromise.complete());
+            return refreshPromise.future();
+        })
+        .compose(v -> {
+            QueryParams query = new QueryParams();
+            query.setFilters(List.of(Constants.DOC_TYPE_DATASET));
+            query.setSize(50);
+            return searchClient.paginate(query, searchResponse -> {
+                List<Hit<JsonData>> hits = searchResponse.hits().hits();
+                for (Hit<JsonData> hit : hits) {
+                    if (hit.source() == null) continue; // Ignore null sources
+                    JsonObject source = new JsonObject(hit.source().toJson().toString());
+                    String id = hit.id();
+
+                    // Check if the dataset contains all the required embedding fields
+                    checkEmbedding(source, id, "title", "title_embedding");
+                    checkEmbedding(source, id, "description", "description_embedding");
+                    checkEmbedding(source, id, "keywords", "keywords_embedding");
+                }
+            });
+        })
+        .onComplete(testContext.succeeding(v -> {
+            testContext.completeNow();
+        }))
+        .onFailure(testContext::failNow);
+  }
+
+  @Test
+  @DisplayName("Test bulk indexing with embeddings")
+  @Timeout(value = 240, timeUnit = java.util.concurrent.TimeUnit.MINUTES) // Embeddings may take a while to generate
+  void testBulkEmbeddingGeneration(Vertx vertx, VertxTestContext testContext) {
+
+    JsonObject esConfig = createElasticsearchTestConfig();
+    IndexManager indexManager = IndexManager.create(vertx, esConfig, null);
+    DatasetsService datasetService = DatasetsService.create(vertx, esConfig, indexManager).result();
+    SearchClient searchClient = SearchClient.build(vertx, esConfig, indexManager);
+
+    // Register mock for CataloguesService
+
+    CataloguesService cataloguesService = mock(CataloguesService.class);
+    when(cataloguesService.resolveCatalogueInPayloadArray(eq(Constants.DOC_TYPE_DATASET), any(JsonArray.class)))
+        .thenAnswer(invocation -> Future.succeededFuture(invocation.getArgument(1)));
+
+    new ServiceBinder(vertx)
+        .setAddress(CataloguesService.SERVICE_ADDRESS)
+        .register(CataloguesService.class, cataloguesService);
+
+    // Register mock for VocabularyService
+
+    VocabularyService vocabularyService = mock(VocabularyService.class);
+    when(vocabularyService.replaceVocabularyInPayloadList(any(JsonArray.class)))
+        .thenAnswer(invocation -> Future.succeededFuture(invocation.getArgument(0)));
+
+    new ServiceBinder(vertx)
+        .setAddress(VocabularyService.SERVICE_ADDRESS)
+        .register(VocabularyService.class, vocabularyService);
+
+    PollingUtils.waitForElasticsearchReady(
+            vertx,
+            esConfig.getString("host", "localhost"),
+            esConfig.getInteger("port", 9200)
+        )
+        .compose(v -> {
+          // Load all existing dataset documents
+          QueryParams query = new QueryParams();
+          query.setFilters(List.of(Constants.DOC_TYPE_DATASET));
+          query.setSize(50);
+          query.setAggregation(false);
+
+          JsonArray datasets = new JsonArray();
+          return searchClient.paginate(query, searchResponse -> {
+            List<Hit<JsonData>> hits = searchResponse.hits().hits();
+            for (Hit<JsonData> hit : hits) {
+              if (hit.source() != null) {
+                JsonObject source = new JsonObject(hit.source().toJson().toString());
+                // Remove embeddings if existing, so they are re-generated
+                source.remove("title_embedding");
+                source.remove("description_embedding");
+                source.remove("keywords_embedding");
+                datasets.add(source);
+              }
+            }
+          }).map(v2 -> datasets);
+        })
+        .compose(datasetService::createOrUpdateDatasetBulk)
+        .compose(v -> {
+            // Wait long enough so that the background processing can finish successfully.
+            // The test will fail if not all dataset-documents have been enriched and indexed with embeddings.
+            Promise<Void> refreshPromise = Promise.promise();
+            vertx.setTimer(2400000, id -> refreshPromise.complete());
+            return refreshPromise.future();
+        })
+        .compose(v -> {
+          // Verify enrichment
+          QueryParams query = new QueryParams();
+          query.setFilters(List.of(Constants.DOC_TYPE_DATASET));
+          query.setSize(50);
+          return searchClient.paginate(query, searchResponse -> {
+            List<Hit<JsonData>> hits = searchResponse.hits().hits();
+            for (Hit<JsonData> hit : hits) {
+              if (hit.source() == null) continue;
+              JsonObject source = new JsonObject(hit.source().toJson().toString());
+              String id = hit.id();
+
+              checkEmbedding(source, id, "title", "title_embedding");
+              checkEmbedding(source, id, "description", "description_embedding");
+              checkEmbedding(source, id, "keywords", "keywords_embedding");
+            }
+          });
+        })
+        .onComplete(testContext.succeeding(v -> testContext.completeNow()))
+        .onFailure(testContext::failNow);
+  }
+
+  private void checkEmbedding(JsonObject source, String id, String sourceField, String embeddingField) {
+
+    if (!source.containsKey(sourceField)) {
+      return;
+    }
+
+    assertTrue(source.containsKey(embeddingField), "Document " + id + " misses embedding " + embeddingField + " although " + sourceField + " field exists");
+
+    JsonArray embedding = source.getJsonArray(embeddingField);
+    assertNotNull(embedding, "Document " + id + " embedding " + embeddingField + " cannot be null");
+    assertFalse(embedding.isEmpty(), "Document " + id + "embedding " + embeddingField + " vector dimension must be greater than 0");
+
+    boolean allZeros = true;
+    for (int i = 0; i < embedding.size(); i++) {
+      if (embedding.getDouble(i) != 0.0) {
+        allZeros = false;
+        break;
+      }
+    }
+    assertFalse(allZeros, "Document " + id + " embedding " + embeddingField + " must not contain all zeros");
+  }
+
+  @Test
+  @DisplayName("Test triggerDatasetEmbeddingEnrichment")
+  @Timeout(value = 240, timeUnit = java.util.concurrent.TimeUnit.MINUTES)
+  void testTriggerDatasetEmbeddingEnrichment(Vertx vertx, VertxTestContext testContext) {
+
+    JsonObject esConfig = createElasticsearchTestConfig();
+    IndexManager indexManager = IndexManager.create(vertx, esConfig, null);
+    DatasetsService datasetService = DatasetsService.create(vertx, esConfig, indexManager).result();
+    SearchClient searchClient = SearchClient.build(vertx, esConfig, indexManager);
+
+    // Register mocks
+    CataloguesService cataloguesService = mock(CataloguesService.class);
+    when(cataloguesService.resolveCatalogueInPayloadArray(eq(Constants.DOC_TYPE_DATASET), any(JsonArray.class)))
+            .thenAnswer(invocation -> Future.succeededFuture(invocation.getArgument(1)));
+    new ServiceBinder(vertx).setAddress(CataloguesService.SERVICE_ADDRESS).register(CataloguesService.class, cataloguesService);
+
+    VocabularyService vocabularyService = mock(VocabularyService.class);
+    when(vocabularyService.replaceVocabularyInPayloadList(any(JsonArray.class)))
+            .thenAnswer(invocation -> Future.succeededFuture(invocation.getArgument(0)));
+    new ServiceBinder(vertx).setAddress(VocabularyService.SERVICE_ADDRESS).register(VocabularyService.class, vocabularyService);
+
+    PollingUtils.waitForElasticsearchReady(vertx, esConfig.getString("host", "localhost"), esConfig.getInteger("port", 9200))
+            .compose(v -> datasetService.triggerDatasetEmbeddingEnrichment())
+            .compose(v -> {
+                // Wait for background processing triggering.
+                Promise<Void> promise = Promise.promise();
+                vertx.setTimer(10000, id -> promise.complete());
+                return promise.future();
+            })
+            .onComplete(testContext.succeeding(v -> testContext.completeNow()))
+            .onFailure(testContext::failNow);
+  }
+
+}
