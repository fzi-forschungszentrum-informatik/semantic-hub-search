@@ -0,0 +1,155 @@
+package io.piveau.hub.search.IntegrationTest;
+
+import io.piveau.hub.search.Constants;
+import io.piveau.hub.search.MainVerticle;
+import io.piveau.hub.search.testutil.PollingUtils;
+import io.vertx.core.DeploymentOptions;
+import io.vertx.core.Vertx;
+import io.vertx.core.json.JsonArray;
+import io.vertx.core.json.JsonObject;
+import io.vertx.ext.web.client.WebClient;
+import io.vertx.junit5.Timeout;
+import io.vertx.junit5.VertxExtension;
+import io.vertx.junit5.VertxTestContext;
+import org.junit.jupiter.api.AfterEach;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.DisplayName;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+
+import java.util.concurrent.TimeUnit;
+
+import static org.junit.jupiter.api.Assertions.*;
+
+@ExtendWith(VertxExtension.class)
+public class HybridDatasetSearchIntegrationTest {
+
+  private WebClient webClient;
+
+  @BeforeEach
+  void setUp(Vertx vertx, VertxTestContext testContext) {
+
+    // For our tests we register a real EmbeddingService (with a local Ollama instance) to the Vert.x event bus
+    // This way we can test real embeddings, not only mocked ones
+    JsonObject embeddingConfig = new JsonObject()
+        .put(Constants.ENV_PIVEAU_HUB_SEARCH_EMBEDDING_CONFIG, new JsonObject()
+            .put("url", "http://localhost:11434")
+            .put("model", "paraphrase-multilingual"));
+
+    testContext.completeNow();
+  }
+
+  @AfterEach
+  void tearDown(Vertx vertx, VertxTestContext testContext) {
+    if (webClient != null) {
+      webClient.close();
+    }
+
+    testContext.completeNow();
+  }
+
+  /**
+   * Creates a test configuration for a piveau-hub-search instance, including
+   * API keys, service ports, feature flags, Elasticsearch configuration, and
+   * embedding service configuration. This configuration is intended for testing
+   * hybrid search with embeddings and ensures the system is set up with predefined values.
+   *
+   * @return a {@link JsonObject} containing the test configuration, including
+   *         API keys, service ports, feature flags, Elasticsearch settings,
+   *         and service parameters for a local embedding service.
+   */
+  private JsonObject createSearchTestConfig() {
+    return new JsonObject()
+        .put("PIVEAU_HUB_SEARCH_API_KEY", "test-api-key")
+        .put("PIVEAU_HUB_SEARCH_SERVICE_PORT", 8080)
+        .put("PIVEAU_FEATURE_FLAGS", new JsonObject().put("rbac_security", false))
+        .put(Constants.ENV_PIVEAU_HUB_SEARCH_ES_CONFIG, createElasticsearchTestConfig())
+        .put(Constants.ENV_PIVEAU_HUB_SEARCH_EMBEDDING_CONFIG, new JsonObject()
+            .put("url", "http://localhost:11434")
+            .put("model", "paraphrase-multilingual"));
+  }
+
+  /**
+   * Creates a test configuration for Elasticsearch, providing host, port, scheme,
+   * and index-specific settings such as mappings, settings files, index templates,
+   * and policies for different document types. The configuration is based on the
+   * default settings and can be used for testing the integration with Elasticsearch.
+   *
+   * @return a {@link JsonObject} representing the Elasticsearch test configuration.
+   */
+  JsonObject createElasticsearchTestConfig() {
+    return new JsonObject()
+        .put("host", "localhost")
+        .put("port", 9200)
+        .put("scheme", "http")
+        .put("index", new JsonObject()
+            .put(Constants.DOC_TYPE_DATASET, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/dataset/standard.json"))
+            .put(Constants.DOC_TYPE_CATALOGUE, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/catalogue/standard.json"))
+            .put(Constants.DOC_TYPE_DATASERVICE, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/dataservice/standard.json"))
+            .put(Constants.DOC_TYPE_VOCABULARY, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json"))
+            // .put("mapping", "conf/elasticsearch/mapping/vocabulary/standard.json"))
+            .put(Constants.DOC_TYPE_DATASETREVISIONS, new JsonObject()
+                .put("settings", "conf/elasticsearch/settings.json")
+                .put("mapping", "conf/elasticsearch/mapping/dataset/standard.json")
+                .put("indexTemplate", "conf/elasticsearch/indexTemplate.json")
+                .put("policy", "conf/elasticsearch/policy.json"))
+        ).put(Constants.DOC_TYPE_VOCABULARY, new JsonObject());
+  }
+
+  @Test
+  @DisplayName("Testing hybrid dataset search")
+  @Timeout(value = 30, timeUnit = TimeUnit.SECONDS) // MainVerticle and embedding model may take a while
+  void testHybridDatasetSearch(Vertx vertx, VertxTestContext testContext) {
+    webClient = WebClient.create(vertx);
+
+    JsonObject searchConfig = createSearchTestConfig();
+    JsonObject esConfig = createElasticsearchTestConfig();
+
+    PollingUtils.waitForElasticsearchReady(vertx, esConfig.getString("host", "localhost"), esConfig.getInteger("port", 9200))
+        .compose(v -> vertx.deployVerticle(MainVerticle.class.getName(), new DeploymentOptions().setConfig(searchConfig)))
+        .compose(deploymentId -> webClient
+            .get(8080,"localhost","/search")
+            .addQueryParam("q", "Rostock")
+            .addQueryParam("filters", Constants.DOC_TYPE_DATASET)
+            .addQueryParam("page", "0")
+            .addQueryParam("limit", "50")
+            .addQueryParam("aggregation", "false")
+            .addQueryParam("semanticSearch", "true")
+            .send())
+        .onComplete(testContext.succeeding(response -> {
+
+          // TODO: Define search term and number of expected results as constants and avoid hardcoding
+
+          // Was HTTP request successful?
+          assertEquals(200, response.statusCode(), response.bodyAsString());
+
+          // Check response structure
+          JsonObject body = response.bodyAsJsonObject();
+          assertNotNull(body, "Response body must contain a JSON response.");
+          assertTrue(body.containsKey("result"), "Response must contain 'result' field");
+
+          JsonObject result = body.getJsonObject("result");
+          assertNotNull(result, "Response field 'result' must not be null.");
+          assertTrue(result.containsKey("count"), "Result must contain 'count' field with the found dataset count.");
+          assertTrue(result.containsKey("results"), "Result must contain 'results' field with the found datasets.");
+
+          // Check number of search results
+          int count = result.getInteger("count");
+          assertEquals(4, count, "Search for 'Rostock' must return exactly 4 datasets.");
+
+          JsonArray results = result.getJsonArray("results");
+          assertNotNull(results, "Result field 'results' must not be null and should contain a list of datasets.");
+          assertEquals(4, results.size(), "Result list must contain exactly 4 datasets");
+
+          testContext.completeNow();
+        }))
+        .onFailure(testContext::failNow);
+  }
+}
