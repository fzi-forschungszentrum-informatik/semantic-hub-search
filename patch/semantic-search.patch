@@ -0,0 +1,91 @@
+package io.piveau.hub.search.services.embeddings;
+
+import io.piveau.hub.search.Constants;
+import io.vertx.core.buffer.Buffer;
+import io.vertx.core.json.JsonArray;
+import io.vertx.core.json.JsonObject;
+import io.vertx.core.Vertx;
+import io.vertx.junit5.VertxExtension;
+import io.vertx.junit5.VertxTestContext;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.DisplayName;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+
+import static org.junit.jupiter.api.Assertions.*;
+
+@ExtendWith(VertxExtension.class)
+public class EmbeddingServiceTest {
+
+  static final int EMBEDDING_SIZE = 768;  // Definiert die Vektor-Dimension für das verwendete Embedding-Modell
+
+  @BeforeEach
+  void setUp(Vertx vertx, VertxTestContext testContext) {
+    // TODO: Implementiere einen Mock-Embedding-Service via `vertx.createHttpServer()` oder Mockito
+    testContext.completeNow();
+  }
+
+  @Test
+  @DisplayName("Test Embedding Service")
+  void testGenerateEmbedding(Vertx vertx, VertxTestContext testContext) {
+
+
+
+    JsonObject config = new JsonObject()
+        .put(Constants.ENV_PIVEAU_HUB_SEARCH_EMBEDDING_CONFIG, new JsonObject()
+            .put("url", "http://localhost:11434")
+            .put("model", "paraphrase-multilingual"));
+
+    EmbeddingService service = new EmbeddingServiceImpl(vertx, config);
+
+    service.generateEmbedding("Fahrrad Verkehrsdaten")
+            .onComplete(testContext.succeeding(embedding -> {
+              assertNotNull(embedding);
+              assertEquals(EMBEDDING_SIZE, embedding.size());
+              // Wir prüfen stichprobenartig drei konkrete Embedding-Werte
+              assertEquals(-0.023943307, embedding.getDouble(0), 0.0001);
+              assertEquals(0.0418487, embedding.getDouble(1), 0.0001);
+              assertEquals(-0.089255266, embedding.getDouble(EMBEDDING_SIZE-1), 0.0001);
+              testContext.completeNow();
+            }));
+  }
+
+  @Test
+  @DisplayName("Test adding embeddings for titles, keywords and descriptions to a DCAT-AP-Dataset.")
+  void testEnrichDocumentWithEmbeddings(Vertx vertx, VertxTestContext testContext) {
+
+    JsonObject config = new JsonObject()
+        .put(Constants.ENV_PIVEAU_HUB_SEARCH_EMBEDDING_CONFIG, new JsonObject()
+            .put("url", "http://localhost:11434")
+            .put("model", "paraphrase-multilingual"));
+
+    EmbeddingService service = new EmbeddingServiceImpl(vertx, config);
+
+    vertx.fileSystem().readFile("documents/dataset1_index_dcatap2.json")
+            .map(Buffer::toJsonObject)
+            .compose(dataset -> service.enrichDatasetWithEmbeddings(dataset))
+            .onSuccess(enrichedDataset -> {
+
+              assertNotNull(enrichedDataset);
+              assertTrue(enrichedDataset.containsKey("title_embedding"));
+              assertTrue(enrichedDataset.containsKey("description_embedding"));
+              assertTrue(enrichedDataset.containsKey("keywords_embedding"));
+
+              JsonArray titleEmbedding = enrichedDataset.getJsonArray("title_embedding");
+              JsonArray descriptionEmbedding = enrichedDataset.getJsonArray("description_embedding");
+              JsonArray keywordsEmbedding = enrichedDataset.getJsonArray("keywords_embedding");
+
+              assertEquals(EMBEDDING_SIZE, titleEmbedding.size());
+              assertEquals(EMBEDDING_SIZE, descriptionEmbedding.size());
+              assertEquals(EMBEDDING_SIZE, keywordsEmbedding.size());
+
+              // Prüfe ob nicht einfach nur einen 0-Vektor zurückgegeben wurde
+              assertTrue(titleEmbedding.stream().anyMatch(v -> (double) v != 0.0));
+              assertTrue(descriptionEmbedding.stream().anyMatch(v -> (double) v != 0.0));
+              assertTrue(keywordsEmbedding.stream().anyMatch(v -> (double) v != 0.0));
+
+              testContext.completeNow();
+            })
+            .onFailure(testContext::failNow);
+  }
+}
