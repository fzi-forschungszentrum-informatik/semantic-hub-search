+package io.piveau.hub.search.services.embeddings;
+
+import io.piveau.hub.search.Constants;
+import io.piveau.json.ConfigHelper;
+import io.vertx.core.Future;
+import io.vertx.core.Vertx;
+import io.vertx.core.json.JsonArray;
+import io.vertx.core.json.JsonObject;
+import io.vertx.ext.web.client.WebClient;
+import io.vertx.ext.web.client.WebClientOptions;
+import io.vertx.ext.web.client.predicate.ResponsePredicate;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+public class EmbeddingServiceImpl implements EmbeddingService {
+
+  private final Logger log = LoggerFactory.getLogger(getClass());
+  private final WebClient webClient;
+  private final String ollamaUrl;
+  private final String model;
+
+  EmbeddingServiceImpl(Vertx vertx, JsonObject config) {
+    // this.webClient = WebClient.create(vertx);
+    this.webClient = WebClient.create(vertx, new WebClientOptions()
+        .setKeepAlive(true)
+        .setMaxPoolSize(3)
+        .setConnectTimeout(10000)
+        .setIdleTimeout(10000));
+
+    // Konfiguration für Ollama-Endpunkt und Modelnamen einlesen
+    JsonObject embeddingConfig = ConfigHelper.forConfig(config).forceJsonObject(Constants.ENV_PIVEAU_HUB_SEARCH_EMBEDDING_CONFIG);
+    this.ollamaUrl = embeddingConfig.getString("url");
+    this.model = embeddingConfig.getString("model");
+  }
+
+  @Override
+  @SuppressWarnings("deprecation")
+  public Future<JsonArray> generateEmbedding(String text) {
+    // Doku für Ollama-Embedding-Endpunkt: https://docs.ollama.com/capabilities/embeddings
+
+    // Für einen leeren Eingabetext gibt Ollama kein Embedding zurück.
+    if (text == null || text.isBlank()) {
+      return Future.succeededFuture(new JsonArray());
+    }
+
+    JsonObject request = new JsonObject()
+        .put("model", model)
+        .put("input", text);
+
+    // TODO: Implementiere Post-Sanity-Check via HttpResponseExpectation
+    // https://vertx.io/blog/http-response-validation-with-the-vert-x-web-client/
+
+    return webClient.postAbs(ollamaUrl + "/api/embed")
+        .putHeader("Content-Type", "application/json")
+        .expect(ResponsePredicate.SC_OK)
+        .sendJsonObject(request)
+        .map(response -> response.bodyAsJsonObject().getJsonArray("embeddings").getJsonArray(0))
+        .onSuccess(response -> {})
+        .onFailure(err -> log.error("Error generating embedding: " + err.getMessage()));
+  }
+
+  @Override
+  public Future<JsonObject> enrichDatasetWithEmbeddings(JsonObject dataset) {
+
+    JsonObject enrichedDataset = dataset.copy();
+
+    // Make sure that no old embeeddings are left
+    enrichedDataset.remove(Constants.FIELD_TITLE_EMBEDDING);
+    enrichedDataset.remove(Constants.FIELD_DESCRIPTION_EMBEDDING);
+    enrichedDataset.remove(Constants.FIELD_KEYWORDS_EMBEDDING);
+
+    // Extract dataset metadata
+    String title = extractTitle(dataset);
+    String description = extractDescription(dataset);
+    String[] keywords = extractKeywords(dataset);
+    String joinedKeywords = String.join(", ", keywords);
+
+    // TODO: Change from info to debug message
+    log.info("Enriching dataset with embeddings: title='{}', descriptionPresent={}, keywordCount={}", title, description != null && !description.isBlank(), keywords.length);
+
+    // Create embedding futures for concurrent embedding generation
+    Future<JsonArray> titleFuture = generateEmbedding(title);
+    Future<JsonArray> descriptionFuture = generateEmbedding(description);
+    Future<JsonArray> keywordsFuture = generateEmbedding(joinedKeywords);
+
+    return Future.all(titleFuture, descriptionFuture, keywordsFuture)
+        .map(composite -> {
+
+          // Add embeddings to dataset metadata
+          JsonArray titleEmbedding = titleFuture.result();
+          if (titleEmbedding != null && !titleEmbedding.isEmpty()) {
+            enrichedDataset.put(Constants.FIELD_TITLE_EMBEDDING, titleEmbedding);
+          }
+
+          JsonArray descriptionEmbedding = descriptionFuture.result();
+          if (descriptionEmbedding != null && !descriptionEmbedding.isEmpty()) {
+            enrichedDataset.put(Constants.FIELD_DESCRIPTION_EMBEDDING, descriptionEmbedding);
+          }
+
+          JsonArray keywordsEmbedding = keywordsFuture.result();
+          if (keywordsEmbedding != null && !keywordsEmbedding.isEmpty()) {
+            enrichedDataset.put(Constants.FIELD_KEYWORDS_EMBEDDING, keywordsEmbedding);
+          }
+
+          return enrichedDataset;
+        })
+        .onFailure(err -> log.error("Error enriching dataset with embeddings: {}", err.getMessage()));
+  }
+
+  /**
+   * Extracts the title from the provided DCAT-AP dataset object. The method prioritizes the title
+   * in the following order: "_lang", "de", "en". If no title is found, it returns null.
+   *
+   * @param dataset the JsonObject representing the DCAT-AP dataset from which the title is extracted
+   * @return the extracted title as a String if found, otherwise null
+   */
+  private String extractTitle(JsonObject dataset) {
+    JsonObject titleObject = dataset.getJsonObject("title");
+    return extractPreferredLanguageString(titleObject);
+  }
+
+  /**
+   * Extracts the description from the provided DCAT-AP dataset object. The method prioritizes the description
+   * in the following order: "_lang", "de", "en". If no description is found, it returns null.
+   *
+   * @param dataset the JsonObject representing the DCAT-AP dataset from which the description text is extracted
+   * @return the extracted description as a String if found, otherwise null
+   */
+  private String extractDescription(JsonObject dataset) {
+    JsonObject descriptionObject = dataset.getJsonObject("description");
+    return extractPreferredLanguageString(descriptionObject);
+  }
+
+  /**
+   * Extracts a non-blank string from the provided JsonObject based on a predefined language priority.
+   * The method searches for keys in the following order: "_lang", "de", "en". If a non-blank string is
+   * found for one of these keys, it is returned. If no valid string is found or if the JsonObject is null,
+   * the method returns null.
+   *
+   * @param multilingualObject the JsonObject containing potential string values for different language keys as found in many DCAT-AP datasets fields
+   * @return the extracted non-blank string based on the language priority, or null if no valid string is found
+   */
+  private String extractPreferredLanguageString(JsonObject multilingualObject) {
+    if (multilingualObject == null) {
+      return null;
+    }
+
+    for (String lang : new String[]{"_lang", "de", "en"}) {
+      String description = multilingualObject.getString(lang);
+      if (description != null && !description.isBlank()) {
+        return description;
+      }
+    }
+
+    return null;
+  }
+
+  /**
+   * Extracts keywords from a provided DCAT-AP dataset object. The keywords are extracted
+   * from the "keywords" field, ensuring that only non-blank labels are returned.
+   *
+   * @param dataset the JsonObject representing the DCAT-AP dataset from which the keywords are extracted
+   * @return an array of Strings representing the extracted keywords, or an empty array if no keywords are found
+   */
+  private String[] extractKeywords(JsonObject dataset) {
+    JsonArray keywords = dataset.getJsonArray("keywords");
+    if (keywords == null) {
+      return new String[0];
+    }
+
+    return keywords.stream()
+        .filter(JsonObject.class::isInstance)
+        .map(JsonObject.class::cast)
+        .map(keywordObject -> keywordObject.getString("label"))
+        .filter(label -> label != null && !label.isBlank())
+        .toArray(String[]::new);
+  }
+
+}
