+    private static Query buildSemanticQuery(QueryParams query) {
+        float semanticBoost = 1.2f;
+        float semanticMinScore = 0.75f;
+        float effectiveSemanticMinScore = semanticMinScore * semanticBoost;
+
+        Map<String, JsonData> scriptParams = new HashMap<>();
+        scriptParams.put("queryVector", JsonData.of(query.getQueryVector()));
+        scriptParams.put("title_weight", JsonData.of(0.5f));
+        scriptParams.put("description_weight", JsonData.of(0.3f));
+        scriptParams.put("keywords_weight", JsonData.of(0.2f));
+        scriptParams.put("semantic_boost", JsonData.of(semanticBoost));
+        scriptParams.put("semantic_min_score", JsonData.of(semanticMinScore));
+
+        return ScriptScoreQuery.of(scriptScore -> scriptScore
+                .query(embeddingExistsQuery())
+                .minScore(effectiveSemanticMinScore)
+                .script(script -> script
+                        .lang("painless")
+                        .params(scriptParams)
+                        .source("""
+                    double weighted_score = 0.0;
+                    double weight_sum = 0.0;
+                    
+                    if (doc['title_embedding'].size() > 0) {
+                        double score = (cosineSimilarity(params.queryVector, 'title_embedding') + 1.0) / 2.0;
+                        weighted_score += score * params.title_weight;
+                        weight_sum += params.title_weight;
+                    }
+
+                    if (doc['description_embedding'].size() > 0) {
+                        double score = (cosineSimilarity(params.queryVector, 'description_embedding') + 1.0) / 2.0;
+                        weighted_score += score * params.description_weight;
+                        weight_sum += params.description_weight;
+                    }
+
+                    if (doc['keywords_embedding'].size() > 0) {
+                        double score = (cosineSimilarity(params.queryVector, 'keywords_embedding') + 1.0) / 2.0;
+                        weighted_score += score * params.keywords_weight;
+                        weight_sum += params.keywords_weight;
+                    }
+                    
+                    double semantic_score = weight_sum > 0 ? weighted_score / weight_sum : 0.0;
+                    
+                    if (semantic_score < params.semantic_min_score) {
+                        return 0.0;
+                    }
+                    
+                    return semantic_score * params.semantic_boost;
+                    """)
+                )
+        )._toQuery();
